# Application
APP_ENV=prod
APP_SECRET=<случайная строка 32+ символов>
APP_PORT=4000
APP_HOST=0.0.0.0

# VLESS / Xray
VLESS_HOST=vpn.example.com
XRAY_LOG_LEVEL=error
XRAY_ENABLE_STATS=0
XRAY_LISTEN_PORT=443
XRAY_PUBLIC_KEY=<reality public key>
XRAY_SHORT_ID=<short id>
XRAY_REALITY_SERVER_NAME=www.cloudflare.com
XRAY_STATS_PORT=10085

# PostgreSQL
POSTGRES_USER=vpn
POSTGRES_PASSWORD=<надёжный пароль>
POSTGRES_DB=vpn
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Telegram Bot
TELEGRAM_BOT_TOKEN=<токен от @BotFather>
BOT_API_BASE=http://api:4000
BOT_SINGLE_ACTIVE=0
BOT_REVOKE_SCOPE=user_node
BOT_FORCE_NEW=0
